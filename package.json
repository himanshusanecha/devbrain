{
  "name": "devbrain",
  "version": "1.0.1",
  "description": "Git-aware context switching layer for AI coding agents via Obsidian vault",
  "main": "dist/mcp-server/index.js",
  "bin": {
    "devbrain": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "vault-template",
    "agent-configs",
    "prompts"
  ],
  "scripts": {
    "dev": "nodemon --exec ts-node src/cli/index.ts mcp",
    "build": "node build.mjs",
    "start": "node dist/cli/index.js mcp",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
